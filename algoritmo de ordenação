class ContaCorrente:
    def __init__(self, numero, titular, saldo=0.0):
        self.numero = numero
        self.titular = titular
        self.saldo = saldo

    def depositar(self, valor):
        if valor > 0:
            self.saldo += valor
            print(f"Depósito de R${valor:.2f} realizado na conta de {self.titular}.")
        else:
            print("Valor de depósito inválido.")

    def sacar(self, valor):
        if 0 < valor <= self.saldo:
            self.saldo -= valor
            print(f"Saque de R${valor:.2f} realizado na conta de {self.titular}.")
        else:
            print("Saldo insuficiente ou valor inválido.")

    def transferir(valor, origem, destino):
        if origem.saldo >= valor and valor > 0:
            origem.sacar(valor)
            destino.depositar(valor)
            print(f"Transferência de R${valor:.2f} realizada de {origem.titular} para {destino.titular}.")
        else:
            print("Transferência não realizada. Verifique o saldo e o valor.")
